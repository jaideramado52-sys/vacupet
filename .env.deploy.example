# VacuPet — secrets de despliegue. Copia a .env.deploy y rellena.
# .env.deploy está en .gitignore (NO lo subas al repo).  (Fase 4 del ROADMAP.)

# --- IA (asistente FAQ veterinaria + OCR del carné) ---
ANTHROPIC_API_KEY=sk-ant-...
FAQ_MODEL=claude-opus-4-8          # o claude-haiku-4-5 para abaratar
OCR_MODEL=claude-opus-4-8
FAQ_ALLOW_ORIGIN=*                 # o https://tudominio para restringir CORS

# --- Firma del QR de integridad (vacupet-sign) ---
# Genera con: node scripts/gen-keys.mjs  → pega aquí el JWK completo
SIGN_PRIVATE_JWK={"kty":"EC","crv":"P-256","x":"...","y":"...","d":"..."}
SIGN_KID=vacupet-1

# --- Recordatorios push (vacupet-push) ---
# Genera con: node scripts/gen-keys.mjs
VAPID_PUBLIC_KEY=B...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:tu-correo@dominio.com

# --- Recordatorios por correo (recordatorios) ---
RESEND_API_KEY=re_...

# --- Protección del cron (opcional pero recomendado) ---
CRON_SECRET=
